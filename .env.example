# MongoDB Atlas Connection String
# Sign up free at https://cloud.mongodb.com
# Create a cluster (M0 free tier) and get your connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/smartdirectory?retryWrites=true&w=majority

# JWT Secrets (generate random strings)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this

# Server
PORT=5000
NODE_ENV=development

# Redis (Optional - app works without it using in-memory cache)
# Sign up free at https://upstash.com for cloud Redis
# REDIS_URL=redis://default:password@host:port

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
