# Environment Variables
PORT=5000
MONGODB_URI=mongodb://localhost:27017/smartdirectory
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
# Frontend CORS URL (Update this in Render environment variables)
FRONTEND_URL=https://new-phonebook.vercel.app
NODE_ENV=development
# VITE_API_URL should be set in the frontend repository to point to this backend URL
